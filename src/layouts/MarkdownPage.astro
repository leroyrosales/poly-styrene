---
import Seo from '../components/Seo.astro';
import site from '../data/site.json';

interface Frontmatter {
	title: string;
	description: string;
	canonicalPath?: string;
}

const { frontmatter } = Astro.props as { frontmatter: Frontmatter };
const { url, author } = site;
const canonicalPath = frontmatter.canonicalPath ?? '/uses';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<title>{frontmatter.title}</title>
		<Seo
			title={frontmatter.title}
			description={frontmatter.description}
			canonicalPath={canonicalPath}
			siteUrl={url}
			author={author}
		/>
		<style is:global>
			@import "../styles/global.css";
		</style>
	</head>
	<body class="px-8 py-12 max-w-3xl mx-auto text-black bg-white">
		<main class="max-w-prose">
			<h1 class="text-3xl font-bold mb-8">{frontmatter.title}</h1>
			<article class="[&_a]:text-green [&_a]:underline [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:text-2xl [&_ul]:list-disc [&_ul]:pl-6">
				<slot />
			</article>
		</main>
	</body>
</html>
