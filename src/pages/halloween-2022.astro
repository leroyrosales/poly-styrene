---
import '../styles/global.css';
import Seo from "../components/Seo.astro";
import site from "../data/site.json";

const { url, author } = site;
const pageTitle = "Halloween 2022 | Leroy Rosales";
const pageDescription = "Seasonal Halloween page — Leroy Rosales.";
---

<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<title>{pageTitle}</title>
		<Seo
			title={pageTitle}
			description={pageDescription}
			canonicalPath="/halloween-2022"
			siteUrl={url}
			author={author}
		/>
		<style is:global>
   .eye {
      display: flex;
      width: 48px;
      height: 48px;
      position: absolute;
      bottom: 50%;
      background: #fff;
      border-radius: 50%;
   }
   .eye-left {
        left: 26px;
      }
      .eye-right {
        right: 26px;
      }
      .eye-inner {
        position: relative;
        display: inline-block;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        background-color: black;
        border-radius: 50%;
        margin-left: 4px;
        margin-top: 4px;
    }
    .eye-inner:after {
          position: absolute;
          top: 2px;
          left: 10px;
          width: 20px;
          height: 20px;
          background: white;
          border-radius: 50%;
          content: " ";
        }
        a:hover {
            cursor: pointer;
        }
        a span[data-dare] {
            display: none;
        }
        a:hover span[data-download] {
            display: none;
        }
        a:hover span[data-dare] {
            display: inline;
        }
		</style>
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@v2.14.0/devicon.min.css">
	</head>

	<body class="bg-black">
        <div class="container w-screen h-screen text-center mx-auto">
            <div class="md:w-1/2 h-1/2 relative mx-auto flex items-end justify-center">
                <div class="eye eye-left">
                    <div class="eye-inner"></div>
                  </div>
                  <div class="eye eye-right">
                    <div class="eye-inner"></div>
                  </div>
                  <a href="https://1drv.ms/u/s!Ai2HKMDnCNJrr6EcNl2Zv8tWQfR9Mw?e=2M664h" class="text-[#FFA500] no-underline  hover:text-white  text-4xl"><span data-download>☠️ Download ☠️</span><span data-dare>👻 If you dare 👻</span></a>
            </div>
        </div>


        <script is:inline>
            const container = document.querySelector(".container");
            if (!container) return;
            container.addEventListener("mousemove", (e) => {
            const eyes = document.querySelectorAll(".eye");
            const ev = /** @type {MouseEvent} */ (e);
            eyes.forEach((eye) => {
                const el = /** @type {HTMLElement} */ (eye);
                let mouseX = el.getBoundingClientRect().right;
                if (el.classList.contains("eye-left")) {
                mouseX = el.getBoundingClientRect().left;
                }
                let mouseY = el.getBoundingClientRect().top;
                let radianDegrees = Math.atan2(ev.pageX - mouseX, ev.pageY - mouseY);
                let rotationDegrees = radianDegrees * (180 / Math.PI) * -1 + 180;
                el.style.transform = `rotate(${rotationDegrees}deg)`;
            });
            });
        </script>
	</body>
</html>
