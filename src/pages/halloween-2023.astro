---
import Seo from "../components/Seo.astro";
import site from "../data/site.json";

const { url, author } = site;
const pageTitle = "Halloween 2023 | Leroy Rosales";
const pageDescription =
	"Halloween 2023 — Ghosthunting with Papi at the Haunted Boodega.";
---

<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<title>{pageTitle}</title>
		<Seo
			title={pageTitle}
			description={pageDescription}
			canonicalPath="/halloween-2023"
			siteUrl={url}
			author={author}
		/>
		<style is:global>
            @import "../styles/global.css";
		</style>
	</head>

	<body class="bg-black">
        <section class="container w-screen h-screen text-center mx-auto">
            <article class="grid grid-cols-1">
                <img class="w-full max-w-[650px] mx-auto py-8" src="../../boodega2x.jpg" alt="Ghosthunting with Papi at the Haunted Boodega">
                  <a href="https://1drv.ms/u/s!Ai2HKMDnCNJrr_IfdufI_aljS9X60A?e=hqzC4M" class="text-[#FFA500] no-underline  hover:text-white  text-4xl"><span data-download>☠️ Download ☠️</span><span data-dare>👻 If you dare 👻</span></a>
            </article>
        </section>
	</body>
</html>
