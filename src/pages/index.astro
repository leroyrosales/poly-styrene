---
import '../styles/global.css';
import '../styles/devicon.min.css';
import Portfolio from "../components/Portfolio.astro";
import Skills from '../components/Skills.astro';
import People from '../components/People.astro';
import Outro from '../components/Outro.astro';
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import Seo from "../components/Seo.astro";
import site from "../data/site.json";
const { author, title, intro, likes, url, metaDescription, socials } = site;

const randomLike = likes[Math.floor(Math.random() * likes.length)].toLowerCase();
const slogan = `I'm just a nerd that likes ${randomLike}.`;

const baseUrl = url.replace(/\/$/, '');
const personLd = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: author,
	url: `${baseUrl}/`,
	jobTitle: 'Full Stack Developer',
	description: metaDescription,
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'Austin',
		addressRegion: 'TX',
		addressCountry: 'US',
	},
	sameAs: socials.map((s) => s.link),
};

---

<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<title>{title}</title>
		<Seo
			title={title}
			description={metaDescription}
			canonicalPath="/"
			siteUrl={url}
			author={author}
		/>
		<script
			type="application/ld+json"
			is:inline
			set:html={JSON.stringify(personLd)}
		/>
	</head>

	<body>
	    <a href="#skills" class="sr-only focus:not-sr-only">
          Skip to skills
        </a>
		<Navbar/>
		<section class="py-24 px-12 border-2 border-black">
			<h1>👨🏾‍💻 {author}</h1>
			<p class="slogan anim-typewriter pb-8">{slogan}</p>
			<p class="text-3xl max-w-prose">{intro}</p>
		</section>
		<main class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3">
			<Portfolio/>
		</main>
		<Skills />
		<Outro />
		<section class="grid grid-cols-1 md:grid-cols-2">
			<People />
			<Footer />
		</section>
	</body>
</html>
